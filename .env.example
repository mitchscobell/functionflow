# Required — JWT signing key (use a long random string in production)
JWT_KEY=local-dev-secret-change-in-production

# Required — Frontend origin for CORS
CORS_ORIGIN=http://localhost:4000

# SMTP — email delivery (leave blank to disable email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional — admin notification email
ADMIN_EMAIL=
