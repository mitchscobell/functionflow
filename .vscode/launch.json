{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Run API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "backend: build",
      "program": "${workspaceFolder}/backend/TodoApi/bin/Debug/net8.0/TodoApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/TodoApi",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5036"
      },
      "console": "integratedTerminal",
      "stopAtEntry": false
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Frontend + Backend",
      "configurations": ["Backend: Run API"],
      "preLaunchTask": "frontend: dev server",
      "stopAll": true
    }
  ]
}
